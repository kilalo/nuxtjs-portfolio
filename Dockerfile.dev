# Dockerfile pour le développement
FROM node:20-alpine

WORKDIR /app

# Copier les fichiers de dépendances
COPY package*.json ./

# Installer les dépendances
RUN npm install

# Copier tous les fichiers du projet
COPY . .

# Exposer le port
EXPOSE 3000

# Lancer en mode développement
CMD ["npm", "run", "dev"]
